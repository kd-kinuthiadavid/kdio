# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Neon Postgres (Drizzle)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Resend (transactional email)
RESEND_API_KEY=
# Must be a verified sender in Resend (e.g. onboarding@resend.dev in dev)
RESEND_FROM_EMAIL=onboarding@resend.dev
# Where owner notifications go
NOTIFY_EMAIL=you@example.com

# Resume links in email + API auth (min 16 chars)
RESUME_JWT_SECRET=

# Vercel Cron (Authorization: Bearer …). On Vercel Hobby, crons run at most once per day — see vercel.json schedule.
CRON_SECRET=

# Upstash Redis (optional — rate limits disabled if unset)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin dashboard
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Cal.com (optional overrides)
NEXT_PUBLIC_CAL_STRATEGY_URL=https://cal.com/kinuthiadavid/15min
NEXT_PUBLIC_CAL_DISCOVERY_URL=https://cal.com/kinuthiadavid/15min
NEXT_PUBLIC_NURTURE_GUIDE_URL=https://cal.com/kinuthiadavid/15min
